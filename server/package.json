{
  "name": "quantumvault-server",
  "version": "0.3.3",
  "private": true,
  "type": "module",
  "bin": {
    "quantumvault": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsx watch --experimental-sqlite src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --experimental-sqlite dist/index.js",
    "cli": "tsx src/cli.ts",
    "test": "node --experimental-sqlite --import tsx --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.2"
  }
}
